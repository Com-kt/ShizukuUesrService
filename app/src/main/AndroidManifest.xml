<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:installLocation="auto">
    
     <queries>
        <package android:name="com.kitty.shizuku" />
        <package android:name="moe.shizuku.privileged.api" />
        <package android:name="com.android.shell" />
     </queries>
     
    <!-- 防止手机休眠 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- 以高采样率访问传感器数据 -->
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />
    <!-- Shizuku V23 -->
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />
    <!-- 使用证书 -->
    <uses-permission android:name="android.permission.USE_CREDENTIALS" />
    <!-- 在后台运行 -->
    <uses-permission android:name="android.permission.REQUEST_COMPANION_RUN_IN_BACKGROUND" />
    <!-- 在后台使用数据 -->
    <uses-permission android:name="android.permission.REQUEST_COMPANION_USE_DATA_IN_BACKGROUND" />
    <!-- 运行前台服务 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- 运行「dataSync」类型的前台服务 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name="app.compile.SuiApplication"
        android:process=":bash"
        android:allowBackup="true" 
        android:directBootAware="false"
        android:usesNonSdkApi="true"
        android:resizeableActivity="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:attributionsAreUserVisible="true"
        android:preserveLegacyExternalStorage="true"
        android:appCategory="productivity"
        android:icon="@mipmap/ic_launcher" 
        android:roundIcon="@mipmap/ic_launcher" 
        android:label="@string/app_name" 
        android:supportsRtl="true" 
        android:theme="@style/Theme.Shizuku"
        tools:targetApi="37">

        <activity-alias
             android:label="@string/apps_name"
             android:name="com.android.shell"
             android:exported="true"
             android:targetActivity="app.compile.MainActivity">
            <intent-filter>
                <action
                    android:name="android.intent.action.MAIN" />
                <category
                    android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        
        <activity
            android:name="app.compile.MainActivity"
            android:process=":bash"
            android:immersive="true"
            android:stateNotNeeded="true"
            android:launchMode="singleInstancePerTask"
            android:windowSoftInputMode="adjustPan"
            android:persistableMode="persistNever"
            android:enableVrMode="true"
            android:exported="true" />
       
       <provider
           android:name="rikka.shizuku.ShizukuProvider"
           android:authorities="com.kitty.shizuku.shizuku"
           android:multiprocess="false"
           android:enabled="true"
           android:exported="true"
           android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />
           
       <provider
            android:name="androidx.core.content.FileProvider"
            android:exported="false"
            android:authorities="com.kitty.shizuku.fileprovider"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file" />
       </provider>
       
    </application>
</manifest>